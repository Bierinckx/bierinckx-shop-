{
  "name": "bierinckx-shop",
  "version": "0.1.0",
  "description": "Een moderne webshop applicatie met e-commerce functionaliteiten",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss build src/styles/main.css -o public/css/style.css",
    "build:js": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.{js,css,html}",
    "validate": "npm run lint && npm run test",
    "prepare": "husky install"
  },
  "keywords": [
    "ecommerce",
    "webshop",
    "javascript",
    "nodejs",
    "express",
    "web-development"
  ],
  "author": {
    "name": "Bierinckx",
    "url": "https://github.com/Bierinckx"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bierinckx/bierinckx-shop-.git"
  },
  "bugs": {
    "url": "https://github.com/Bierinckx/bierinckx-shop-/issues"
  },
  "homepage": "https://github.com/Bierinckx/bierinckx-shop-#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "mongoose": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "tailwindcss": "^3.4.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.{css,html,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}